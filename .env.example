# Stock Agent — Environment Variables
# Copy this file to .env and fill in your values.

# OpenAI API key (required for AI-powered news summaries)
OPENAI_API_KEY=sk-...

# Email / SMTP settings (can also be set in portfolio.yaml)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Optional: Finnhub API key for additional news sources
# FINNHUB_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# LinkedIn Agent — additional env vars (only needed for `linkedin-agent`)
# ─────────────────────────────────────────────────────────────────────────────

# LinkedIn API credentials. Run `linkedin-agent oauth` once to obtain these.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_URN=urn:li:person:xxxxx

# HMAC secret shared with the Cloudflare Worker. Generate with:
#   openssl rand -hex 32
APPROVAL_HMAC_SECRET=

# Public URL of your deployed Cloudflare Worker (the Approver).
# Example: https://linkedin-approver.your-sub.workers.dev
APPROVER_WORKER_URL=

# Override the LLM used by the writer. Default: gpt-4o.
# LINKEDIN_AGENT_MODEL=gpt-4o

# Minimum impact score (0-10) of the top trend required to post.
# Below this we skip the run instead of posting filler. Default: 6.0
# LINKEDIN_AGENT_MIN_IMPACT=6.0

# Per-trend quality floor: EVERY one of the 3 trends used in a post must
# score at least this. If not, skip the run. Default: 5.0
# LINKEDIN_AGENT_QUALITY_FLOOR=5.0

# Lookback window in hours for the trend search + RSS pass.
# 24 = daily cadence, 168 = weekly (default).
# LINKEDIN_AGENT_LOOKBACK_HOURS=168

# Path to your voice samples file. Default: voice.yaml in CWD.
# LINKEDIN_AGENT_VOICE=voice.yaml

# When running outside GitHub Actions you must set these explicitly:
# LINKEDIN_AGENT_REPO_OWNER=varunmaliknit
# LINKEDIN_AGENT_REPO_NAME=learn
# GITHUB_TOKEN=ghp_...  # fine-grained PAT with contents+issues write
