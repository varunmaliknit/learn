# Stock Agent — Environment Variables
# Copy this file to .env and fill in your values.

# OpenAI API key (required for AI-powered news summaries)
OPENAI_API_KEY=sk-...

# Email / SMTP settings (can also be set in portfolio.yaml)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Optional: Finnhub API key for additional news sources
# FINNHUB_API_KEY=
